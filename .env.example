NODE_ENV=development
PORT=4000
CLIENT_ORIGIN=http://localhost:5173
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=ceo_user
DB_PASSWORD=ceo_password
DB_NAME=ceo_command_center
DB_CONNECTION_LIMIT=10
JWT_SECRET="replace-with-a-long-random-secret"
AUTH_COOKIE_NAME=ceo_cc_token
CEO_EMAIL=ceo@example.com
CEO_PASSWORD=ChangeMe123!
INGESTION_CRON=0 6 * * *
DEFAULT_TIMEZONE=Asia/Kolkata
INVENTORY_DAYS_TARGET_MIN=60
INVENTORY_DAYS_TARGET_MAX=90
SNAPSHOT_DISCOVERY_START=07:25
SNAPSHOT_DISCOVERY_END=09:00
SNAPSHOT_DISCOVERY_INTERVAL_MINUTES=5
SNAPSHOT_MAINTENANCE_CRON=30 11,15,19,23 * * *
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json
GOOGLE_SERVICE_ACCOUNT_JSON=
# Leave empty for production (same-origin /api via reverse proxy) and local dev (Vite proxies /api → :4000).
# Set to http://localhost:4000 only if the API runs on another origin without a proxy.
VITE_API_BASE_URL=
