# Example nginx site for CEO Command Center (HTTP).
# Replace server_name with your public hostname or IP.

server {
    listen 80;
    server_name 172.236.180.56;

    root /var/www/ceo-command-center/client/dist;
    index index.html;

    # SPA — serve index.html for client routes
    location / {
        try_files $uri $uri/ /index.html;
    }

    # API reverse proxy
    location /api/ {
        proxy_pass http://127.0.0.1:4000;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Authorization $http_authorization;
        proxy_pass_header Set-Cookie;
    }

    # Static asset caching
    location /assets/ {
        expires 7d;
        add_header Cache-Control "public, immutable";
    }
}
