{
  "name": "@ceo-command-center/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/src/index.js",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "db:create": "tsx scripts/createDatabase.ts",
    "db:schema": "tsx scripts/runSql.ts sql/002_create_tables.sql && tsx scripts/runSql.ts sql/003_snapshot_discovery.sql && tsx scripts/runSql.ts sql/004_snapshot_metrics.sql && tsx scripts/runSql.ts sql/005_pbt_monthly_inputs.sql && tsx scripts/runSql.ts sql/006_snapshot_metrics_inventory_days.sql && tsx scripts/runSql.ts sql/007_hr_expenses.sql && tsx scripts/runSql.ts sql/008_pbt_additional_indirect.sql && tsx scripts/backfillSnapshotMetrics.ts",
    "db:backfill-metrics": "tsx scripts/backfillSnapshotMetrics.ts",
    "db:seed": "tsx scripts/seed.ts",
    "copq:refresh": "tsx scripts/refreshCopq.ts",
    "copq:seed-audit": "tsx scripts/seedCopqAudit.ts",
    "db:setup": "npm run db:create && npm run db:schema && npm run db:seed"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "csv-parse": "^6.2.1",
    "decimal.js": "^10.6.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "googleapis": "^173.0.0",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.11.0",
    "mysql2": "^3.22.5",
    "node-cron": "^4.2.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/node": "^25.9.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
